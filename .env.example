# Devin API Configuration
DEVIN_API_KEY=your_devin_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
SUPERSET_REPO=your_superset_repo
REMEDY_REPO=your_rem_repo

# Server Configuration
WEBHOOK_SECRET=your_webhook_secret_for_github_verification
PORT=5000

# Dependabot scanner (dependabot_scan.py)
SCAN_REPO=maidang111/superset
# Minimum severity to dispatch to Devin: low | medium | high | critical
SEVERITY_THRESHOLD=low
# Safety cap on sessions opened per run
MAX_DISPATCH=5
# If an upgrade cascades to more than this many OTHER packages, Devin flags the PR
# for human review instead of auto-fixing.
MAX_CASCADE=2
# High-blast-radius packages that must get a reviewed Devin upgrade (never an
# unreviewed insta-bump), even when Dependabot already opened a PR. The primary
# list lives in a file (see SENSITIVE_PACKAGES_FILE); this env var adds extras
# on top of it (comma-separated).
SENSITIVE_PACKAGES=
# File the sensitive-package list is read from (one package per line, "#" comments ok).
SENSITIVE_PACKAGES_FILE=sensitive_packages.txt
# Where processed-alert state is persisted (keeps re-runs idempotent)
DEPENDABOT_STATE_FILE=.dependabot_state.json
# Seconds before any HTTP request (GitHub / Devin) times out
REQUEST_TIMEOUT=30
# --reconcile: how many times a stuck session (no PR, or red CI) is nudged before
# the alert is escalated to a human (tracking issue filed).
MAX_RETRIES=2
# Directory holding the Devin prompt templates (routine_upgrade.md, reviewed_upgrade.md,
# vulnerability_details.md). Defaults to the templates/ dir next to the script.
# PROMPT_TEMPLATE_DIR=templates
