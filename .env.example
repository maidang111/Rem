# Devin API Configuration
DEVIN_API_KEY=your_devin_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
SUPERSET_REPO=maidang111/superset
REMEDY_REPO=maidang111/Remedy

# Server Configuration
WEBHOOK_SECRET=your_webhook_secret_for_github_verification
PORT=5000

# Dependabot scanner (dependabot_scan.py)
SCAN_REPO=maidang111/superset
# Safety cap on sessions opened per run (highest-severity alerts are dispatched first)
MAX_DISPATCH=5
# High-blast-radius packages that must get a reviewed Devin upgrade (never an
# unreviewed insta-bump), even when Dependabot already opened a PR. Comma-separated.
SENSITIVE_PACKAGES=
# Where processed-alert state is persisted (keeps re-runs idempotent)
DEPENDABOT_STATE_FILE=.dependabot_state.json
